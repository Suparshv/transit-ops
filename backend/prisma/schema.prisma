// TransitOps — Prisma Schema
// Joy owns this file. FuelLog and Expense write paths belong to Suparshv.
// SQLite: no Prisma enums — status fields are plain strings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int      @id @default(autoincrement())
  email               String   @unique
  passwordHash        String
  failedLoginAttempts Int      @default(0)
  isLocked            Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Vehicle {
  id                 Int      @id @default(autoincrement())
  registrationNumber String   @unique
  name               String
  type               String
  capacityKg         Float
  odometerKm         Float    @default(0)
  acquisitionCost    Float    @default(0)
  status             String   @default("Available")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]
}

model Driver {
  id                Int      @id @default(autoincrement())
  name              String
  licenseNumber     String   @unique
  licenseCategory   String
  licenseExpiryDate DateTime
  contact           String
  tripCompletionPct Float    @default(0)
  status            String   @default("Available")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  trips Trip[]
}

model Trip {
  id                 Int      @id @default(autoincrement())
  source             String
  destination        String
  vehicleId          Int
  driverId           Int
  cargoWeightKg      Float
  plannedDistanceKm  Float
  finalOdometerKm    Float?
  fuelConsumedLiters Float?
  fuelCost           Float?
  status             String   @default("Draft")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  vehicle  Vehicle   @relation(fields: [vehicleId], references: [id])
  driver   Driver    @relation(fields: [driverId], references: [id])
  fuelLogs FuelLog[]
  expenses Expense[]
}

model MaintenanceLog {
  id          Int      @id @default(autoincrement())
  vehicleId   Int
  serviceType String
  cost        Float
  date        DateTime
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle  Vehicle   @relation(fields: [vehicleId], references: [id])
  expenses Expense[]
}

model FuelLog {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  tripId    Int?
  date      DateTime
  liters    Float
  fuelCost  Float
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  trip    Trip?   @relation(fields: [tripId], references: [id])
}

model Expense {
  id               Int      @id @default(autoincrement())
  tripId           Int?
  vehicleId        Int
  toll             Float    @default(0)
  other            Float    @default(0)
  maintenanceCost  Float    @default(0)
  maintenanceLogId Int?
  total            Float    @default(0)
  status           String   @default("Pending")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  vehicle        Vehicle         @relation(fields: [vehicleId], references: [id])
  trip           Trip?           @relation(fields: [tripId], references: [id])
  maintenanceLog MaintenanceLog? @relation(fields: [maintenanceLogId], references: [id])
}

model Settings {
  id           Int    @id @default(autoincrement())
  depotName    String @default("TransitOps Depot")
  currency     String @default("INR (₹)")
  distanceUnit String @default("Kilometers")
}
